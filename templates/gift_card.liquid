<!doctype html><html><head><meta charset="utf-8"><title>{{ shop.name }} Gift Card</title></head>
<body style="font-family:sans-serif;text-align:center;padding:60px">
<h1>{{ shop.name }} Gift Card</h1>
<p style="font-size:28px">{{ gift_card.initial_value | money }}</p>
<p>Code: <strong>{{ gift_card.code | format_code }}</strong></p>
{% if gift_card.qr_identifier %}{{ gift_card.qr_identifier | qr_code: 180 }}{% endif %}
</body></html>
