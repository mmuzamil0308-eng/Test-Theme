<div class="wrap" style="padding-top:48px;padding-bottom:90px">
  <div style="text-align:center;max-width:600px;margin:0 auto 50px">
    <div class="eyebrow">Collection</div>
    <h1 class="serif" style="font-weight:500;font-size:clamp(34px,4.5vw,52px);margin:0 0 14px;color:var(--c-dark)">{{ collection.title }}</h1>
    {% if collection.description != blank %}
      <p style="font-size:15.5px;color:var(--c-muted);line-height:1.6">{{ collection.description }}</p>
    {% endif %}
  </div>

  {% if collection.products.size == 0 %}
    <p style="text-align:center;color:var(--c-muted)">No products found in this collection yet.</p>
  {% else %}
    {% paginate collection.products by 24 %}
      <div class="pgrid">
        {% for product in collection.products %}
          {% render 'product-card', product: product %}
        {% endfor %}
      </div>
      {% if paginate.pages > 1 %}
        <div style="display:flex;justify-content:center;gap:10px;margin-top:50px">
          {{ paginate | default_pagination }}
        </div>
      {% endif %}
    {% endpaginate %}
  {% endif %}
</div>

{% schema %}
{ "name": "Collection page", "settings": [] }
{% endschema %}
