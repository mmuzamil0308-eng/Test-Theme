<section id="about" class="wrap" style="padding-top:104px;padding-bottom:104px">
  <div class="story-grid">
    <div data-reveal class="story-media">
      <div class="story-media__main">
        {% if section.settings.main_image %}
          <img src="{{ section.settings.main_image | image_url: width: 900 }}" alt="">
        {% else %}
          <img src="{{ 'story-main.jpg' | asset_url }}" alt="">
        {% endif %}
      </div>
      {% if section.settings.detail_image %}
        <img src="{{ section.settings.detail_image | image_url: width: 500 }}" class="story-media__detail" alt="">
      {% else %}
        <img src="{{ 'product-fallback.jpg' | asset_url }}" class="story-media__detail" alt="">
      {% endif %}
      <div class="story-media__stat">
        <b class="serif">{{ section.settings.stat_number }}</b>
        <span>{{ section.settings.stat_label }}</span>
      </div>
    </div>
    <div data-reveal class="story-text">
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h2 class="serif">{{ section.settings.heading }}</h2>
      <p>{{ section.settings.body }}</p>
      <div class="story-points">
        {% for block in section.blocks %}
          <div class="story-point">
            <span class="story-point__icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="m5 13 4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <div>
              <div class="story-point__title">{{ block.settings.title }}</div>
              <div class="story-point__text">{{ block.settings.text }}</div>
            </div>
          </div>
        {% endfor %}
      </div>
      <a href="{{ section.settings.cta_link }}" class="btn btn-olive">{{ section.settings.cta_label }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ingredients story",
  "settings": [
    { "type": "image_picker", "id": "main_image", "label": "Main image" },
    { "type": "image_picker", "id": "detail_image", "label": "Detail image" },
    { "type": "text", "id": "stat_number", "label": "Stat number", "default": "100%" },
    { "type": "text", "id": "stat_label", "label": "Stat label", "default": "Natural & Pure" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Sourced with Intention" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "From the soil of South Asia to your daily ritual" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Every Hunza Herbs formulation begins with whole, traceable botanicals, including hand-selected ashwagandha, shilajit, kaunch, safed musli and rare unani herbs. No fillers, no synthetic additives, no shortcuts." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Discover the Range" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "blocks": [
    { "type": "point", "name": "Point", "settings": [
      { "type": "text", "id": "title", "label": "Title" },
      { "type": "text", "id": "text", "label": "Text" }
    ]}
  ],
  "default": {
    "blocks": [
      { "type": "point", "settings": { "title": "Hand-selected herbs", "text": "Sourced directly from growers we trust." } },
      { "type": "point", "settings": { "title": "Traditional extraction", "text": "Methods preserved across generations." } },
      { "type": "point", "settings": { "title": "Third-party tested", "text": "Every batch checked for purity." } }
    ]
  },
  "presets": [{ "name": "Ingredients story" }]
}
{% endschema %}
