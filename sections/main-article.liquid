<div class="wrap" style="padding-top:48px;padding-bottom:90px;max-width:760px">
  <h1 class="serif" style="font-size:clamp(34px,4.5vw,52px);margin:0 0 16px;color:var(--c-dark)">{{ article.title }}</h1>
  <p style="font-size:13px;color:var(--c-muted2);margin:0 0 30px">{{ article.published_at | date: "%B %d, %Y" }} &middot; {{ article.author }}</p>
  {% if article.image %}<img src="{{ article.image | image_url: width: 1200 }}" style="border-radius:6px;margin-bottom:30px">{% endif %}
  <div style="font-size:16px;line-height:1.75;color:#5c5046;font-weight:300">{{ article.content }}</div>
</div>
{% schema %}{ "name": "Article", "settings": [] }{% endschema %}
