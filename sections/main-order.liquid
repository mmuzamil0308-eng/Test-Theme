<div class="wrap" style="padding:48px 32px">
  <h1 class="serif" style="font-size:32px;color:var(--c-dark)">Order {{ order.name }}</h1>
  {% for line_item in order.line_items %}
    <div style="border-bottom:1px solid var(--c-border);padding:14px 0">{{ line_item.title }} x {{ line_item.quantity }} &mdash; {{ line_item.final_line_price | money }}</div>
  {% endfor %}
  <p style="margin-top:20px;font-weight:600">Total: {{ order.total_price | money }}</p>
</div>
{% schema %}{ "name": "Order", "settings": [] }{% endschema %}
