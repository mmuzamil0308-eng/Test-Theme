<div class="announce-bar">
  {% for block in section.blocks %}
    <span{% if forloop.first %} style="opacity:.92"{% else %} style="opacity:.92"{% endif %}>{{ block.settings.text }}</span>{% unless forloop.last %}<span class="dot">&bull;</span>{% endunless %}
  {% endfor %}
</div>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [],
  "blocks": [
    { "type": "item", "name": "Message", "settings": [
      { "type": "text", "id": "text", "label": "Text", "default": "Complimentary shipping over Rs 5,000" }
    ]}
  ],
  "default": {
    "blocks": [
      { "type": "item", "settings": { "text": "Complimentary shipping over Rs 5,000" } },
      { "type": "item", "settings": { "text": "Cash on Delivery across Pakistan" } },
      { "type": "item", "settings": { "text": "100% Authentic Herbal Formulations" } }
    ]
  }
}
{% endschema %}
