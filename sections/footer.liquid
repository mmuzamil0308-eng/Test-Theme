<footer id="contact" class="site-footer">
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <div style="display:flex;align-items:center;gap:11px;margin-bottom:22px">
          <span style="width:38px;height:38px;border-radius:50%;border:1.5px solid #B87333;display:flex;align-items:center;justify-content:center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 21c0-7 4-11 9-12-1 8-4 11-9 12Z" fill="#9bb06a"/><path d="M12 21C12 14 8 10 3 9c1 8 4 11 9 12Z" fill="#B87333" opacity=".85"/></svg>
          </span>
          <span style="display:flex;flex-direction:column;line-height:1">
            <span class="serif" style="font-size:24px;font-weight:600;letter-spacing:.06em;white-space:nowrap">{{ section.settings.logo_text | default: shop.name }}</span>
            <span style="font-size:8.5px;letter-spacing:.4em;text-transform:uppercase;color:#B87333;margin-top:3px">{{ section.settings.tagline }}</span>
          </span>
        </div>
        <p style="font-size:14px;line-height:1.7;color:rgba(255,253,246,.6);max-width:320px;margin:0 0 24px;font-weight:300">{{ section.settings.about_text }}</p>
        <div class="social-row">
          {% if section.settings.facebook != blank %}<a href="{{ section.settings.facebook }}" aria-label="Facebook"><svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.4 2.9h-2.4v7A10 10 0 0 0 22 12Z"/></svg></a>{% endif %}
          {% if section.settings.instagram != blank %}<a href="{{ section.settings.instagram }}" aria-label="Instagram"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1"/></svg></a>{% endif %}
          {% if section.settings.tiktok != blank %}<a href="{{ section.settings.tiktok }}" aria-label="TikTok"><svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M16 3a5 5 0 0 0 5 5v3a8 8 0 0 1-5-1.7V15a6 6 0 1 1-6-6c.3 0 .7 0 1 .1v3.1a3 3 0 1 0 2 2.8V3h3Z"/></svg></a>{% endif %}
          {% if section.settings.whatsapp != blank %}<a href="{{ section.settings.whatsapp }}" aria-label="WhatsApp"><svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.5 15.2L2 22l4.9-1.5A10 10 0 1 0 12 2Z" opacity=".15"/><path d="M17 14.4c-.3-.2-1.8-.9-2.1-1-.3-.1-.5-.1-.7.1-.2.3-.7 1-.9 1.1-.2.1-.4.2-.7 0-1-.4-2.6-1.7-3.4-3-.2-.3-.1-.5.1-.7.2-.2.5-.5.6-.7.1-.2.1-.4 0-.6-.1-.2-.7-1.7-.9-2.2-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.4-.2.3-.9 1-1 2.4-.1 1.4 1 3 1.2 3.2.2.2 2.3 3.6 5.6 4.7 3.3 1.1 3.3.7 3.9.6.6-.1 1.8-.7 2-1.5.2-.7.2-1.3.1-1.5-.1-.1-.2-.2-.5-.4Z"/></svg></a>{% endif %}
        </div>
      </div>

      {% for block in section.blocks %}
        <div class="footer-col">
          <div class="footer-col-title">{{ block.settings.title }}</div>
          {% for link in block.settings.menu.links %}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        </div>
      {% endfor %}

      <div>
        <div class="footer-col-title">Get in Touch</div>
        <div style="display:flex;flex-direction:column;gap:16px;font-size:14px;color:rgba(255,253,246,.68);font-weight:300">
          <div style="display:flex;gap:12px;align-items:flex-start"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#B87333" stroke-width="1.6" style="flex:none;margin-top:2px"><path d="M12 21s7-5.5 7-11a7 7 0 1 0-14 0c0 5.5 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg>{{ section.settings.address }}</div>
          <div style="display:flex;gap:12px;align-items:flex-start"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#B87333" stroke-width="1.6" style="flex:none;margin-top:2px"><path d="M4 5h16v14H4zM4 7l8 6 8-6"/></svg>{{ section.settings.email }}</div>
          <div style="display:flex;gap:12px;align-items:flex-start"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#B87333" stroke-width="1.6" style="flex:none;margin-top:2px"><path d="M5 4h4l2 5-3 2a12 12 0 0 0 5 5l2-3 5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2Z"/></svg>{{ section.settings.phone }}</div>
        </div>
        <div style="margin-top:24px;display:flex;gap:8px;flex-wrap:wrap">
          <span style="background:rgba(255,253,246,.08);border:1px solid rgba(255,253,246,.15);font-size:11px;padding:7px 12px;border-radius:3px;letter-spacing:.04em">Cash on Delivery</span>
          <span style="background:rgba(255,253,246,.08);border:1px solid rgba(255,253,246,.15);font-size:11px;padding:7px 12px;border-radius:3px;letter-spacing:.04em">Secure Checkout</span>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div>&copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All rights reserved.</div>
      <div style="display:flex;gap:24px">
        <a href="{{ pages.privacy-policy.url | default: '#' }}">Privacy Policy</a>
        <a href="{{ pages.terms-of-service.url | default: '#' }}">Terms of Service</a>
        <a href="{{ pages.shipping-returns.url | default: '#' }}">Shipping &amp; Returns</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "logo_text", "label": "Logo text", "default": "HUNZA HERBS" },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Herbal · Ayurveda" },
    { "type": "textarea", "id": "about_text", "label": "About text", "default": "Pakistan's premium herbal wellness house. Traditional formulations, modern standards, delivered to your door." },
    { "type": "text", "id": "address", "label": "Address", "default": "Gulberg III, Lahore, Pakistan" },
    { "type": "text", "id": "email", "label": "Email", "default": "care@hunzaherbs.pk" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "+92 300 1234567" },
    { "type": "url", "id": "facebook", "label": "Facebook URL" },
    { "type": "url", "id": "instagram", "label": "Instagram URL" },
    { "type": "url", "id": "tiktok", "label": "TikTok URL" },
    { "type": "url", "id": "whatsapp", "label": "WhatsApp URL" }
  ],
  "blocks": [
    { "type": "link_column", "name": "Link column", "settings": [
      { "type": "text", "id": "title", "label": "Title" },
      { "type": "link_list", "id": "menu", "label": "Menu" }
    ]}
  ],
  "default": {
    "blocks": [
      { "type": "link_column", "settings": { "title": "Shop" } },
      { "type": "link_column", "settings": { "title": "Company" } }
    ]
  }
}
{% endschema %}
