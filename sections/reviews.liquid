<section id="reviews" class="reviews-section">
  <div class="wrap" style="padding-top:100px;padding-bottom:100px">
    <div data-reveal class="section-head" style="max-width:620px">
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h2 class="serif">{{ section.settings.heading }}</h2>
      <div class="rating-pill">
        <span style="display:flex;gap:2px;color:var(--c-copper)">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <span style="font-size:14px;color:var(--c-dark);font-weight:500">{{ section.settings.rating }} / 5</span>
        <span style="font-size:13px;color:var(--c-muted)">from {{ section.settings.review_count }} reviews</span>
      </div>
    </div>
    <div class="review-grid">
      {% for block in section.blocks %}
        <div data-reveal class="review-card">
          <div class="review-card__head">
            {% if block.settings.avatar %}
              <img src="{{ block.settings.avatar | image_url: width: 90 }}" class="review-card__avatar" alt="">
            {% else %}
              <span class="review-card__avatar" style="display:inline-block"></span>
            {% endif %}
            <div>
              <div class="review-card__name">{{ block.settings.name }}</div>
              <div class="review-card__loc">{{ block.settings.location }} &middot; Verified Buyer</div>
            </div>
          </div>
          <div class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="review-card__text">{{ block.settings.text }}</p>
          <div class="review-card__product">Purchased &middot; {{ block.settings.product }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Reviews",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Verified Customer Stories" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Trusted by thousands across Pakistan" },
    { "type": "text", "id": "rating", "label": "Rating", "default": "4.9" },
    { "type": "text", "id": "review_count", "label": "Review count", "default": "4,200+" }
  ],
  "blocks": [
    { "type": "review", "name": "Review", "settings": [
      { "type": "image_picker", "id": "avatar", "label": "Avatar" },
      { "type": "text", "id": "name", "label": "Name" },
      { "type": "text", "id": "location", "label": "Location" },
      { "type": "textarea", "id": "text", "label": "Review text" },
      { "type": "text", "id": "product", "label": "Product purchased" }
    ]}
  ],
  "default": {
    "blocks": [
      { "type": "review", "settings": { "name": "Ayesha K.", "location": "Karachi", "text": "Genuinely the best herbal supplements I have tried. Real, gentle results.", "product": "Majoon e Khaas" } },
      { "type": "review", "settings": { "name": "Bilal R.", "location": "Islamabad", "text": "Quick delivery and packaging felt premium. The product itself works great.", "product": "Shilajit Resin" } },
      { "type": "review", "settings": { "name": "Sana M.", "location": "Lahore", "text": "Customer service answered every question before I ordered. Very trustworthy brand.", "product": "Ashwagandha Capsules" } },
      { "type": "review", "settings": { "name": "Hamza T.", "location": "Faisalabad", "text": "Three weeks in, energy levels are noticeably better. Will reorder.", "product": "Hawwa Tonic" } }
    ]
  },
  "presets": [{ "name": "Reviews" }]
}
{% endschema %}
