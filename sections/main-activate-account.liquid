<div class="wrap" style="padding:60px 32px;max-width:440px;margin:0 auto">
  <h1 class="serif" style="font-size:28px;color:var(--c-dark);margin:0 0 20px;text-align:center">Activate Account</h1>
  {% form 'activate_customer_password' %}
    <input type="password" name="customer[password]" placeholder="Password" required style="width:100%;padding:14px;margin-bottom:12px;border:1px solid var(--c-border2);border-radius:3px">
    <input type="password" name="customer[password_confirmation]" placeholder="Confirm password" required style="width:100%;padding:14px;margin-bottom:16px;border:1px solid var(--c-border2);border-radius:3px">
    <button type="submit" class="btn btn-dark" style="width:100%">Activate Account</button>
  {% endform %}
</div>
{% schema %}{ "name": "Activate account", "settings": [] }{% endschema %}
