<section id="shop" class="wrap" style="padding-top:104px;padding-bottom:60px">
  <div data-reveal class="section-head">
    <div class="eyebrow">{{ section.settings.eyebrow }}</div>
    <h2 class="serif">{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subheading }}</p>
  </div>
  <div class="cat-grid">
    {% for block in section.blocks %}
      {% assign coll = collections[block.settings.collection] %}
      <a href="{{ coll.url | default: '#' }}" data-reveal class="cat-card">
        {% if block.settings.image %}
          <img src="{{ block.settings.image | image_url: width: 700 }}" alt="{{ block.settings.label }}">
        {% elsif coll.featured_image %}
          <img src="{{ coll.featured_image | image_url: width: 700 }}" alt="{{ block.settings.label }}">
        {% else %}
          <img src="{{ 'product-fallback.jpg' | asset_url }}" alt="{{ block.settings.label }}">
        {% endif %}
        <div class="cat-card__shade"></div>
        <div class="cat-card__body">
          <div class="cat-card__count">{{ coll.products_count | default: block.settings.count }} Products</div>
          <div class="cat-card__name serif">{{ block.settings.label }}</div>
          <div class="cat-card__link">Explore collection
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
        </div>
      </a>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Category grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by Concern" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Wellness, thoughtfully curated" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Targeted herbal collections, each formulated around a single wellness goal." }
  ],
  "blocks": [
    { "type": "category", "name": "Category", "settings": [
      { "type": "collection", "id": "collection", "label": "Collection" },
      { "type": "text", "id": "label", "label": "Label" },
      { "type": "text", "id": "count", "label": "Fallback product count" },
      { "type": "image_picker", "id": "image", "label": "Fallback image" }
    ]}
  ],
  "default": {
    "blocks": [
      { "type": "category", "settings": { "label": "Vitality & Energy", "count": "12" } },
      { "type": "category", "settings": { "label": "Sleep & Calm", "count": "8" } },
      { "type": "category", "settings": { "label": "Immunity", "count": "10" } },
      { "type": "category", "settings": { "label": "Digestive Health", "count": "7" } },
      { "type": "category", "settings": { "label": "Skin & Beauty", "count": "9" } },
      { "type": "category", "settings": { "label": "Men's Wellness", "count": "6" } }
    ]
  },
  "presets": [{ "name": "Category grid" }]
}
{% endschema %}
