<div style="min-height:80vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:32px">
  <div>
    <h1 class="serif" style="font-size:clamp(34px,5vw,56px);color:var(--c-dark);margin:0 0 16px">{{ shop.name }}</h1>
    <p style="color:var(--c-muted);margin:0 0 30px">We're putting the finishing touches on something special.</p>
    {% form 'storefront_password' %}
      <input type="password" name="password" placeholder="Enter store password" style="padding:14px;border:1px solid var(--c-border2);border-radius:3px;margin-right:10px">
      <button type="submit" class="btn btn-olive">Enter</button>
    {% endform %}
  </div>
</div>
{% schema %}{ "name": "Password", "settings": [] }{% endschema %}
