<section class="wrap" style="padding-bottom:100px">
  <div data-reveal class="newsletter-box">
    <div style="position:absolute;top:-60px;right:-40px;width:260px;height:260px;border-radius:50%;background:rgba(184,115,51,.22);filter:blur(8px)"></div>
    <div style="position:absolute;bottom:-90px;left:-50px;width:300px;height:300px;border-radius:50%;background:rgba(255,253,246,.07)"></div>
    <div style="position:relative;max-width:560px;margin:0 auto">
      <div class="eyebrow" style="color:var(--c-tan)">{{ section.settings.eyebrow }}</div>
      <h2 class="serif">{{ section.settings.heading }}</h2>
      <p>{{ section.settings.body }}</p>
      {% form 'customer', id: 'newsletter-form', data-newsletter-form: true %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="newsletter-form">
          <input type="email" name="contact[email]" placeholder="Your email address" required>
          <button type="submit" class="btn btn-copper">{{ section.settings.button_label }}</button>
        </div>
      {% endform %}
      <div style="font-size:11.5px;color:rgba(255,253,246,.55);margin-top:16px">No spam. Unsubscribe anytime. Read our privacy policy.</div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Join the Hunza Herbs Circle" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Wellness wisdom, exclusive offers" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Health tips, early access to new formulations, and members-only pricing, sent straight to your inbox." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
