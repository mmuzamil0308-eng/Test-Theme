<div class="wrap" style="padding-top:48px;padding-bottom:90px">
  <h1 class="serif" style="font-weight:500;font-size:clamp(34px,4.5vw,52px);margin:0 0 30px;color:var(--c-dark)">Search results for "{{ search.terms }}"</h1>
  {% if search.results.size == 0 %}
    <p style="color:var(--c-muted)">No results found. Try a different search.</p>
  {% else %}
    <div class="pgrid">
      {% for item in search.results %}
        {% if item.object_type == 'product' %}
          {% render 'product-card', product: item %}
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</div>
{% schema %}{ "name": "Search", "settings": [] }{% endschema %}
