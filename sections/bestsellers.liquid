<section id="products" class="wrap" style="padding-top:64px;padding-bottom:90px">
  <div data-reveal style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:20px;margin-bottom:14px">
    <div>
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h2 class="serif" style="font-weight:500;font-size:clamp(34px,4.5vw,52px);margin:0;line-height:1.05;color:var(--c-dark)">{{ section.settings.heading }}</h2>
    </div>
    <a href="{{ section.settings.collection.url | default: '/collections/all' }}" class="btn btn-outline">View all products</a>
  </div>

  <div class="pgrid" style="margin-top:36px">
    {% assign coll = collections[section.settings.collection] %}
    {% if coll.products.size > 0 %}
      {% for product in coll.products limit: section.settings.product_limit %}
        {% render 'product-card', product: product %}
      {% endfor %}
    {% else %}
      <p style="grid-column:1/-1;text-align:center;color:var(--c-muted);padding:30px 0">Add products to a collection and select it in this section's settings to show them here.</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Bestsellers",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Loved by Thousands" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our bestselling formulations" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_limit", "label": "Products to show", "min": 2, "max": 12, "step": 1, "default": 6 }
  ],
  "presets": [{ "name": "Bestsellers" }]
}
{% endschema %}
